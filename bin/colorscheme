#!/bin/bash
# colorscheme
#
# Switch colorscheme for Ghostty, Helix, Zellij, Btop, Bat and Delta simultaneously.
#
# Requirements:
#   brew install gnu-sed
#
# Adding a new theme:
#   Just add a line to the THEMES array below. Format:
#   "shortname|Ghostty Theme Name|helix_theme_name|zellij-theme-name|btop-theme-name|bat-theme-name"
#   Use '=' if the theme name is the same as the shortname, '-' if unsupported by that tool.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'
quiet_output="false"

info() {
    if [ "$quiet_output" != "true" ]; then
        echo -e "${BLUE}[INFO]${NC} $1"
    fi
}
success() {
    if [ "$quiet_output" != "true" ]; then
        echo -e "${GREEN}[SUCCESS]${NC} $1"
    fi
}
warn() {
    if [ "$quiet_output" != "true" ]; then
        echo -e "${YELLOW}[WARN]${NC} $1"
    fi
}
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# ============================================
# Theme Registry (single source of truth)
# Format: "shortname|ghostty|helix|zellij|btop|bat"
# If a tool's theme name matches the shortname, use '=' as a placeholder.
# Use '-' if a theme is not supported by a specific tool (will be skipped).
#
# Ghostty theme names: run `ghostty +list-themes` to list all available themes.
# Helix theme names:   run `hx --health` or check ~/.config/helix/runtime/themes/.
# Zellij theme names:  check built-in themes in zellij docs.
# Btop theme names:    check ~/.config/btop/themes/ or btop built-in themes.
# Bat theme names:     run `bat --list-themes`; custom `.tmTheme` themes under
#                      `~/.config/bat/themes/` are supported after `bat cache --build`.
# Delta syntax themes: most presets reuse Bat's syntect theme, but Delta-specific
#                      features may be applied for themes that cannot reuse custom
#                      Bat themes directly (for example `tokyonight` / `rose-pine` /
#                      `kanagawa` / `one-dark` / `everforest` / `everforest-light` /
#                      `dayfox`).
# ============================================
THEMES=(
    "dracula|Dracula|=|dracula-pro|=|Dracula"
    "catppuccin|Catppuccin Macchiato|catppuccin_macchiato|catppuccin-macchiato|catppuccin-macchiato|Catppuccin Macchiato"
    "catppuccin-latte|Catppuccin Latte|catppuccin_latte|catppuccin-latte|catppuccin-latte|Catppuccin Latte"
    "rose-pine|Rose Pine|rose_pine|rose-pine|rose-pine|rose-pine"
    "tokyonight|TokyoNight Moon|tokyonight_moon|tokyo-night|tokyo-night|tokyonight_moon"
    "gruvbox|Gruvbox Material Dark|gruvbox_dark_hard|=|gruvbox_material_dark|gruvbox-dark"
    "gruvbox-light|Gruvbox Light|gruvbox_light|gruvbox-light|gruvbox_light|gruvbox-light"
    "kanagawa|Kanagawa Wave|kanagawa|=|kanagawa-wave|kanagawa"
    "nord|Nord|nord|nord|=|Nord"
    "solarized|Solarized Dark Higher Contrast|solarized_dark|solarized-dark|solarized_dark|Solarized (dark)"
    "one-dark|Atom One Dark|one_dark|onedark|onedark|one-dark"
    "everforest|Everforest Dark Hard|everforest_dark|everforest-dark|everforest-dark-hard|everforest"
    "everforest-light|Everforest Light Med|everforest_light|everforest-light|everforest-light-medium|everforest-light"
    "dayfox|Dayfox|dayfox|dayfox|dayfox|dayfox"
)

# Check for gsed (GNU sed)
if ! command -v gsed &>/dev/null; then
    error "gsed (GNU sed) is required but not found. Please 'brew install gnu-sed'."
    exit 1
fi
SED_BIN="gsed"

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}

ghostty_config="$config_home/ghostty/config"
helix_config="$config_home/helix/config.toml"
zellij_config="$config_home/zellij/config.kdl"
btop_config="$config_home/btop/btop.conf"
bat_config="$config_home/bat/config"
gitconfig="$config_home/git/config"
dotfiles_repo_root=""
error_output_mode="usage"
script_path=""

print_heading() {
    printf '%s\n' "$1"
}

resolve_script_path() {
    local source_path="${BASH_SOURCE[0]}"
    local source_dir=""
    local target_path=""

    if [[ "$source_path" != */* ]]; then
        source_path="$(command -v "$source_path")"
    fi

    while [ -L "$source_path" ]; do
        source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
        target_path="$(readlink "$source_path")"
        if [[ "$target_path" = /* ]]; then
            source_path="$target_path"
        else
            source_path="$source_dir/$target_path"
        fi
    done

    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

detect_dotfiles_repo_root() {
    local script_path=""
    local script_dir=""

    script_path="$(resolve_script_path)"
    script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"

    if git -C "$script_dir/.." rev-parse --show-toplevel >/dev/null 2>&1; then
        git -C "$script_dir/.." rev-parse --show-toplevel
        return 0
    fi

    return 1
}

show_usage() {
    cat <<'EOF'
Usage:
  colorscheme <name>
  colorscheme --interactive
  colorscheme --current
  colorscheme --list
  colorscheme --help

Options:
  -i, --interactive Show fzf theme picker with live preview
  -c, --current     Show current theme values only
  -l, --list        Show built-in theme presets only
  -h, --help        Show this help message

Note:
  Only built-in themes from `colorscheme --list` are supported.
EOF
}

get_ghostty_theme() {
    if [ -f "$ghostty_config" ]; then
        grep -E '^theme\s*=' "$ghostty_config" | "$SED_BIN" -E 's/^theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_helix_theme() {
    if [ -f "$helix_config" ]; then
        grep -E '^theme\s*=' "$helix_config" | "$SED_BIN" -E 's/^theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_zellij_theme() {
    if [ -f "$zellij_config" ]; then
        grep -E '^theme\s' "$zellij_config" | "$SED_BIN" -E 's/^theme\s+"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_btop_theme() {
    if [ -f "$btop_config" ]; then
        grep -E '^color_theme\s*=' "$btop_config" | "$SED_BIN" -E 's/^color_theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_bat_theme() {
    if [ -f "$bat_config" ]; then
        "$SED_BIN" -n -E 's/^--theme="?([^"]+)"?$/\1/p' "$bat_config" | head -1
    fi
}

get_delta_theme() {
    if [ -f "$gitconfig" ]; then
        awk '
            $0 == "[delta]" { in_delta=1; next }
            /^\[/ { in_delta=0 }
            in_delta && /^[[:space:]]+syntax-theme[[:space:]]*=/ {
                sub(/^[[:space:]]+syntax-theme[[:space:]]*=[[:space:]]*/, "", $0)
                print
                exit
            }
        ' "$gitconfig"
    fi
}

get_delta_feature() {
    if [ -f "$gitconfig" ]; then
        awk '
            $0 == "[delta]" { in_delta=1; next }
            /^\[/ { in_delta=0 }
            in_delta && /^[[:space:]]+features[[:space:]]*=/ {
                sub(/^[[:space:]]+features[[:space:]]*=[[:space:]]*/, "", $0)
                print
                exit
            }
        ' "$gitconfig"
    fi
}

get_delta_display_theme() {
    local feature=""
    feature="$(get_delta_feature)"
    if [ -n "$feature" ]; then
        printf '%s\n' "$feature"
    else
        get_delta_theme
    fi
}

theme_prefers_light_mode() {
    case "$1" in
        catppuccin-latte|gruvbox-light|everforest-light|dayfox)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

delta_prefers_light_mode() {
    theme_prefers_light_mode "$1"
}

list_theme_names() {
    local entry=""
    local name=""

    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ <<<"$entry"
        printf '%s\n' "$name"
    done
}

theme_position() {
    local target="$1"
    local entry=""
    local name=""
    local index=1

    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ <<<"$entry"
        if [ "$name" = "$target" ]; then
            printf '%s\n' "$index"
            return 0
        fi
        index=$((index + 1))
    done

    return 1
}

theme_name_at_position() {
    local target_position="$1"
    local entry=""
    local name=""
    local index=1

    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ <<<"$entry"
        if [ "$index" -eq "$target_position" ]; then
            printf '%s\n' "$name"
            return 0
        fi
        index=$((index + 1))
    done

    return 1
}

bat_has_theme() {
    local theme="$1"
    if ! command -v bat &>/dev/null; then
        return 1
    fi
    bat --list-themes --paging=never --color=never 2>/dev/null | grep -Fx "$theme" >/dev/null
}

ensure_bat_theme_available() {
    local theme="$1"
    local theme_file=""

    if [ "$theme" = "-" ]; then
        return 0
    fi

    if bat_has_theme "$theme"; then
        return 0
    fi

    if ! command -v bat &>/dev/null; then
        return 0
    fi

    theme_file="$config_home/bat/themes/$theme.tmTheme"
    if [ ! -f "$theme_file" ]; then
        return 0
    fi

    info "Building bat theme cache for $theme..."
    if ! bat cache --build >/dev/null 2>&1; then
        error "failed to build bat cache for theme: $theme"
        return 1
    fi

    if ! bat_has_theme "$theme"; then
        error "bat theme still unavailable after cache build: $theme"
        return 1
    fi

    success "Bat theme cache updated: $theme"
}

print_current_theme() {
    local label="$1"
    local value="$2"
    printf '  %-8s: %s\n' "$label" "${value:-not set}"
}

print_change() {
    local label="$1"
    local old_value="$2"
    local new_value="$3"
    success "$label: ${old_value:-not set} -> ${new_value:-not set}"
}

print_unchanged_warning() {
    local label="$1"
    local current_value="$2"
    local reason="$3"
    warn "$label: ${current_value:-not set} (unchanged, $reason)"
}

reload_ghostty_if_running() {
    local reload_result=""

    if [ "$(uname -s)" != "Darwin" ]; then
        return 0
    fi

    if ! command -v osascript &>/dev/null; then
        return 0
    fi

    # 不能依赖 pgrep 判断 GUI App 是否在运行：
    # Ghostty 的实际进程名可能因宿主形态或大小写差异而变化，容易误判。
    # 这里改用 macOS 原生 AppleScript 查询应用进程，再直接触发 `reload_config`。
    if reload_result="$(osascript 2>/dev/null <<'EOF'
tell application "System Events"
    set ghostty_running to (exists application process "Ghostty") or (exists application process "ghostty")
end tell

if not ghostty_running then
    return "not-running"
end if

using terms from application "Ghostty"
    tell application "Ghostty"
        if (count of every terminal) is 0 then
            return "no-terminals"
        end if

        perform action "reload_config" on first terminal
        return "reloaded"
    end tell
end using terms from
EOF
)"; then
        case "$reload_result" in
            reloaded)
                success "Ghostty config reloaded automatically"
                ;;
            not-running)
                info "Ghostty is not running; the new theme will apply on next launch."
                ;;
            no-terminals)
                warn "Ghostty is running without open terminals; reload skipped"
                ;;
            *)
                warn "Ghostty auto-reload returned an unexpected result: $reload_result"
                ;;
        esac
    else
        warn "Ghostty auto-reload failed; press Cmd + Shift + , manually."
    fi
}

# Show current theme from config files
show_current() {
    print_heading "Current theme:"
    print_current_theme "Ghostty" "$(get_ghostty_theme)"
    print_current_theme "Helix" "$(get_helix_theme)"
    print_current_theme "Zellij" "$(get_zellij_theme)"
    print_current_theme "Btop" "$(get_btop_theme)"
    print_current_theme "Bat" "$(get_bat_theme)"
    print_current_theme "Delta" "$(get_delta_display_theme)"
}

# List available themes
list_themes() {
    local name=""

    print_heading "Available themes:"

    printf '  Dark themes:\n'
    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ _ _ <<<"$entry"
        if ! theme_prefers_light_mode "$name"; then
            printf '    %s\n' "$name"
        fi
    done

    printf '  Light themes:\n'
    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ _ _ <<<"$entry"
        if theme_prefers_light_mode "$name"; then
            printf '    %s\n' "$name"
        fi
    done
}

show_overview() {
    show_current
    printf '\n'
    list_themes
    printf '\n'
    show_usage
}

theme_exists() {
    local name="$1"

    for entry in "${THEMES[@]}"; do
        IFS='|' read -r entry_name _ <<<"$entry"
        if [ "$entry_name" = "$name" ]; then
            return 0
        fi
    done

    return 1
}

find_theme_by_tool_value() {
    local expected="$1"
    local field="$2"
    local entry=""
    local name=""
    local value=""

    if [ -z "$expected" ]; then
        return 1
    fi

    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ <<<"$entry"
        value="$(lookup_theme "$name" "$field")"
        if [ "$value" = "$expected" ]; then
            printf '%s\n' "$name"
            return 0
        fi
    done

    return 1
}

delta_display_theme_for_preset() {
    local preset="$1"
    local syntax_theme=""

    syntax_theme="$(lookup_theme "$preset" 5)"
    if [ "$syntax_theme" = "-" ]; then
        return 1
    fi

    case "$preset" in
        tokyonight)
            printf '%s\n' "tokyonight-moon"
            ;;
        rose-pine|kanagawa|one-dark|everforest|everforest-light|dayfox)
            printf '%s\n' "$preset"
            ;;
        *)
            printf '%s\n' "$syntax_theme"
            ;;
    esac
}

detect_current_preset() {
    local current_value=""

    current_value="$(get_ghostty_theme)"
    if find_theme_by_tool_value "$current_value" 1; then
        return 0
    fi

    current_value="$(get_helix_theme)"
    if find_theme_by_tool_value "$current_value" 2; then
        return 0
    fi

    current_value="$(get_zellij_theme)"
    if find_theme_by_tool_value "$current_value" 3; then
        return 0
    fi

    current_value="$(get_btop_theme)"
    if find_theme_by_tool_value "$current_value" 4; then
        return 0
    fi

    current_value="$(get_bat_theme)"
    if find_theme_by_tool_value "$current_value" 5; then
        return 0
    fi

    current_value="$(get_delta_display_theme)"
    if [ -n "$current_value" ]; then
        local entry=""
        local name=""
        local expected=""

        for entry in "${THEMES[@]}"; do
            IFS='|' read -r name _ <<<"$entry"
            if expected="$(delta_display_theme_for_preset "$name" 2>/dev/null)"; then
                if [ "$expected" = "$current_value" ]; then
                    printf '%s\n' "$name"
                    return 0
                fi
            fi
        done
    fi

    return 1
}

preset_matches_current() {
    local preset="$1"
    local current_preset=""

    if ! current_preset="$(detect_current_preset)"; then
        return 1
    fi

    [ "$current_preset" = "$preset" ]
}

# Lookup theme name for a specific tool.
# $1 = shortname, $2 = field index (1=ghostty, 2=helix, 3=zellij, 4=btop, 5=bat)
lookup_theme() {
    local name="$1" field="$2"
    for entry in "${THEMES[@]}"; do
        IFS='|' read -r entry_name ghostty helix zellij btop bat <<< "$entry"
        if [ "$entry_name" = "$name" ]; then
            local values=("$entry_name" "$ghostty" "$helix" "$zellij" "$btop" "$bat")
            local result="${values[$field]}"
            # '=' means same as shortname
            if [ "$result" = "=" ]; then
                echo "$name"
            else
                echo "$result"
            fi
            return
        fi
    done

    error "Unsupported theme: $name"
    return 1
}

parse_args() {
    local arg=""

    colorscheme=""
    mode="apply"
    error_output_mode="usage"

    if [ "$#" -eq 0 ]; then
        mode="overview"
        return 0
    fi

    while [ "$#" -gt 0 ]; do
        arg="$1"
        case "$arg" in
            -h|--help)
                mode="help"
                shift
                ;;
            -i|--interactive)
                mode="interactive"
                shift
                ;;
            -l|--list)
                mode="list"
                shift
                ;;
            -c|--current)
                mode="current"
                shift
                ;;
            --)
                shift
                if [ "$#" -ne 1 ]; then
                    error "Expected exactly one theme name after '--'."
                    return 1
                fi
                colorscheme="$1"
                shift
                break
                ;;
            -*)
                error "Unknown option: $arg"
                return 1
                ;;
            *)
                if [ -n "$colorscheme" ]; then
                    error "Only one theme name can be provided."
                    return 1
                fi
                colorscheme="$arg"
                shift
                ;;
        esac

        if [ "$mode" != "apply" ] && [ "$#" -gt 0 ]; then
            error "Option '$arg' does not accept additional arguments."
            return 1
        fi
    done

    if [ "$mode" != "apply" ]; then
        return 0
    fi

    if [ -z "$colorscheme" ]; then
        error "Missing theme name."
        return 1
    fi

    if ! theme_exists "$colorscheme"; then
        error "Unsupported theme: $colorscheme. Run 'colorscheme --list' to see allowed themes."
        error_output_mode="themes"
        return 1
    fi

    return 0
}

ghostty_cs_change() {
    local old_theme=""
    if [ ! -f "$ghostty_config" ]; then
        error "ghostty config not found: $ghostty_config"
        return 1
    fi

    old_theme="$(get_ghostty_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 1)
    "$SED_BIN" -i -E "s/^theme\s*=.*/theme = \"$theme\"/" "$ghostty_config"
    print_change "Ghostty theme" "$old_theme" "$theme"
}

helix_cs_change() {
    local old_theme=""
    if [ ! -f "$helix_config" ]; then
        error "helix config not found: $helix_config"
        return 1
    fi

    old_theme="$(get_helix_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 2)
    "$SED_BIN" -i -E "s/^theme\s*=.*/theme = \"$theme\"/" "$helix_config"
    print_change "Helix theme" "$old_theme" "$theme"
}

zellij_cs_change() {
    local old_theme=""
    if [ ! -f "$zellij_config" ]; then
        error "zellij config not found: $zellij_config"
        return 1
    fi

    old_theme="$(get_zellij_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 3)
    "$SED_BIN" -i -E "s/^theme\s+\"[^\"]*\"/theme \"$theme\"/" "$zellij_config"
    print_change "Zellij theme" "$old_theme" "$theme"
}

btop_cs_change() {
    local old_theme=""
    if [ ! -f "$btop_config" ]; then
        error "btop config not found: $btop_config"
        return 1
    fi

    old_theme="$(get_btop_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 4)
    "$SED_BIN" -i -E "s/^color_theme\s*=.*/color_theme = \"$theme\"/" "$btop_config"
    print_change "Btop theme" "$old_theme" "$theme"
}

bat_cs_change() {
    local old_theme=""
    local theme
    old_theme="$(get_bat_theme)"
    theme=$(lookup_theme "$colorscheme" 5)
    if [ "$theme" = "-" ]; then
        print_unchanged_warning "Bat theme" "$old_theme" "preset unsupported"
        return 0
    fi
    if [ ! -f "$bat_config" ]; then
        error "bat config not found: $bat_config"
        return 1
    fi
    ensure_bat_theme_available "$theme"
    if grep -Eq '^--theme=' "$bat_config"; then
        "$SED_BIN" -i -E 's/^--theme=.*/--theme="'"$theme"'"/' "$bat_config"
    elif grep -Eq '^#--theme=' "$bat_config"; then
        "$SED_BIN" -i -E 's/^#--theme=.*/--theme="'"$theme"'"/' "$bat_config"
    else
        printf '\n--theme="%s"\n' "$theme" >> "$bat_config"
    fi
    print_change "Bat theme" "$old_theme" "$theme"
}

delta_cs_change() {
    local old_theme=""
    local new_theme=""
    local syntax_theme=""
    local delta_feature=""
    local delta_light="false"
    if [ ! -f "$gitconfig" ]; then
        error "gitconfig not found: $gitconfig"
        return 1
    fi

    old_theme="$(get_delta_display_theme)"
    syntax_theme=$(lookup_theme "$colorscheme" 5)
    if [ "$syntax_theme" = "-" ]; then
        print_unchanged_warning "Delta theme" "$old_theme" "preset unsupported"
        return 0
    fi

    if delta_prefers_light_mode "$colorscheme"; then
        delta_light="true"
    fi

    case "$colorscheme" in
        tokyonight)
            # Delta cannot consume Bat's custom Tokyo Night syntect theme directly.
            # Use the official Tokyo Night Delta feature instead.
            syntax_theme="Dracula"
            delta_feature="tokyonight-moon"
            ;;
        rose-pine)
            # Delta also cannot reuse Bat's custom Rose Pine syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Rose Pine diff palette.
            syntax_theme="Dracula"
            delta_feature="rose-pine"
            ;;
        kanagawa)
            # Delta cannot reuse Bat's custom Kanagawa syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Kanagawa diff palette.
            syntax_theme="Dracula"
            delta_feature="kanagawa"
            ;;
        one-dark)
            # Delta cannot reuse Bat's custom One Dark syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the One Dark diff palette.
            syntax_theme="Dracula"
            delta_feature="one-dark"
            ;;
        everforest)
            # Delta cannot reuse Bat's custom Everforest syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Everforest diff palette.
            syntax_theme="Dracula"
            delta_feature="everforest"
            ;;
        everforest-light)
            # Delta cannot reuse Bat's custom Everforest Light syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Everforest Light diff palette.
            syntax_theme="Dracula"
            delta_feature="everforest-light"
            ;;
        dayfox)
            # Delta cannot reuse Bat's custom Dayfox syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Dayfox diff palette.
            syntax_theme="Dracula"
            delta_feature="dayfox"
            ;;
    esac

    "$SED_BIN" -i -E '/^\[delta\]/,/^\[/ s/^(\s+)syntax-theme\s*=.*/\1syntax-theme = '"$syntax_theme"'/' "$gitconfig"
    "$SED_BIN" -i -E '/^\[delta\]/,/^\[/ s/^(\s+)light\s*=.*/\1light = '"$delta_light"'/' "$gitconfig"

    if [ -n "$delta_feature" ]; then
        git config --file="$gitconfig" delta.features "$delta_feature"
        new_theme="$delta_feature"
    else
        git config --file="$gitconfig" --unset-all delta.features >/dev/null 2>&1 || true
        new_theme="$syntax_theme"
    fi

    print_change "Delta theme" "$old_theme" "$new_theme"
}

sync_theme_clean_filter() {
    if [ -n "$dotfiles_repo_root" ]; then
        git -C "$dotfiles_repo_root" add \
            ghostty/dot-config/ghostty/config \
            helix/dot-config/helix/config.toml \
            zellij/dot-config/zellij/config.kdl \
            btop/dot-config/btop/btop.conf \
            bat/dot-config/bat/config \
            git/dot-config/git/config 2>/dev/null || true
    fi
}

apply_colorscheme() {
    local sync_git="${1:-true}"

    ghostty_cs_change
    helix_cs_change
    zellij_cs_change
    btop_cs_change
    bat_cs_change
    delta_cs_change

    if [ "$sync_git" = "true" ]; then
        sync_theme_clean_filter
    fi

    reload_ghostty_if_running
}

build_interactive_apply_command() {
    local state_file="$1"
    local escaped_script_path=""
    local escaped_state_file=""

    escaped_script_path="$(printf '%q' "$script_path")"
    escaped_state_file="$(printf '%q' "$state_file")"
    printf "%s --interactive-apply '{}' %s || true" "$escaped_script_path" "$escaped_state_file"
}

run_interactive_apply() {
    local theme="${1:-}"
    local state_file="${2:-}"
    local previous_theme=""

    if [ -z "$theme" ]; then
        error "Missing theme name for interactive apply."
        return 1
    fi

    if ! theme_exists "$theme"; then
        error "Unsupported theme: $theme"
        return 1
    fi

    if [ -n "$state_file" ] && [ -f "$state_file" ]; then
        previous_theme="$(<"$state_file")"
        if [ "$previous_theme" = "$theme" ]; then
            return 0
        fi
    fi

    if preset_matches_current "$theme"; then
        if [ -n "$state_file" ]; then
            printf '%s\n' "$theme" > "$state_file"
        fi
        return 0
    fi

    quiet_output="true"
    colorscheme="$theme"
    apply_colorscheme "false"

    if [ -n "$state_file" ]; then
        printf '%s\n' "$theme" > "$state_file"
    fi
}

run_interactive_picker() {
    local current_preset=""
    local default_position="1"
    local initial_state_theme=""
    local state_file=""
    local apply_command=""
    local fzf_status=0

    if ! command -v fzf &>/dev/null; then
        error "fzf is required for interactive mode. Please 'brew install fzf'."
        return 1
    fi

    if current_preset="$(detect_current_preset 2>/dev/null)"; then
        if ! default_position="$(theme_position "$current_preset")"; then
            default_position="1"
        fi
    fi

    initial_state_theme="$(theme_name_at_position 1)"
    state_file="$(mktemp -t colorscheme-interactive.XXXXXX)"
    printf '%s\n' "$initial_state_theme" > "$state_file"
    apply_command="$(build_interactive_apply_command "$state_file")"

    set +e
    list_theme_names | fzf \
        --sync \
        --with-shell="/bin/bash -c" \
        --layout=reverse \
        --height=80% \
        --border \
        --cycle \
        --highlight-line \
        --prompt="Theme > " \
        --header="Move focus to apply theme immediately" \
        --footer="Enter or Esc to exit" \
        --bind "start:pos($default_position)" \
        --bind "focus:execute-silent($apply_command)" \
        --bind "enter:accept" \
        >/dev/null
    fzf_status=$?
    set -e

    rm -f "$state_file"
    sync_theme_clean_filter

    case "$fzf_status" in
        0|130)
            return 0
            ;;
        *)
            error "fzf exited unexpectedly with status: $fzf_status"
            return "$fzf_status"
            ;;
    esac
}

main() {
    script_path="$(resolve_script_path)"

    if dotfiles_repo_root="$(detect_dotfiles_repo_root)"; then
        :
    else
        dotfiles_repo_root=""
    fi

    if [ "${1:-}" = "--interactive-apply" ]; then
        shift
        run_interactive_apply "$@"
        return $?
    fi

    parse_args "$@" || {
        printf '\n'
        case "$error_output_mode" in
            themes)
                list_themes
                ;;
            *)
                show_usage
                ;;
        esac
        exit 1
    }

    case "$mode" in
        overview)
            show_overview
            return 0
            ;;
        help)
            show_usage
            return 0
            ;;
        current)
            show_current
            return 0
            ;;
        list)
            list_themes
            return 0
            ;;
        interactive)
            run_interactive_picker
            return $?
            ;;
    esac

    apply_colorscheme "true"
}

main "$@"
