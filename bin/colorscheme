#!/bin/bash
# colorscheme
#
# Switch colorscheme for Ghostty, Helix, Zellij, Btop, Bat and Delta simultaneously.
#
# Requirements:
#   brew install gnu-sed
#
# Adding a new theme:
#   Just add a line to the THEMES array below. Format:
#   "shortname|Ghostty Theme Name|helix_theme_name|zellij-theme-name|btop-theme-name|bat-theme-name"
#   Use '=' if the theme name is the same as the shortname, '-' if unsupported by that tool.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# ============================================
# Theme Registry (single source of truth)
# Format: "shortname|ghostty|helix|zellij|btop|bat"
# If a tool's theme name matches the shortname, use '=' as a placeholder.
# Use '-' if a theme is not supported by a specific tool (will be skipped).
#
# Ghostty theme names: run `ghostty +list-themes` to list all available themes.
# Helix theme names:   run `hx --health` or check ~/.config/helix/runtime/themes/.
# Zellij theme names:  check built-in themes in zellij docs.
# Btop theme names:    check ~/.config/btop/themes/ or btop built-in themes.
# Bat theme names:     run `bat --list-themes`; custom `.tmTheme` themes under
#                      `~/.config/bat/themes/` are supported after `bat cache --build`.
# Delta syntax themes: most presets reuse Bat's syntect theme, but Delta-specific
#                      features may be applied for themes that cannot reuse custom
#                      Bat themes directly (for example `tokyonight` / `rose-pine`).
# ============================================
THEMES=(
    "dracula|Dracula|=|dracula-pro|=|Dracula"
    "catppuccin|Catppuccin Macchiato|catppuccin_macchiato|catppuccin-macchiato|catppuccin-macchiato|Catppuccin Macchiato"
    "rose-pine|Rose Pine|rose_pine|rose-pine|rose-pine|rose-pine"
    "tokyonight|TokyoNight Moon|tokyonight_moon|tokyo-night|tokyo-night|tokyonight_moon"
    "gruvbox|Gruvbox Material Dark|gruvbox_dark_hard|=|gruvbox_material_dark|gruvbox-dark"
    "gruvbox-light|Gruvbox Light|gruvbox_light|gruvbox-light|gruvbox_light|gruvbox-light"
    "kanagawa|Kanagawa Wave|kanagawa|=|kanagawa-wave|-"
    "nord|Nord|nord|nord|=|Nord"
    "solarized-dark|Solarized Dark Higher Contrast|solarized_dark|=|solarized_dark|Solarized (dark)"
    "solarized-light|iTerm2 Solarized Light|solarized_light|solarized-light|solarized_light|Solarized (light)"
    "one-dark|Atom One Dark|one_dark|=|onedark|-"
    "everforest|Everforest Dark Hard|everforest_dark|=|everforest-dark-hard|-"
)

# Check for gsed (GNU sed)
if ! command -v gsed &>/dev/null; then
    error "gsed (GNU sed) is required but not found. Please 'brew install gnu-sed'."
    exit 1
fi
SED_BIN="gsed"

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}

ghostty_config="$config_home/ghostty/config"
helix_config="$config_home/helix/config.toml"
zellij_config="$config_home/zellij/config.kdl"
btop_config="$config_home/btop/btop.conf"
bat_config="$config_home/bat/config"
gitconfig="$config_home/git/config"
dotfiles_repo_root=""

print_heading() {
    printf '%s\n' "$1"
}

resolve_script_path() {
    local source_path="${BASH_SOURCE[0]}"
    local source_dir=""
    local target_path=""

    if [[ "$source_path" != */* ]]; then
        source_path="$(command -v "$source_path")"
    fi

    while [ -L "$source_path" ]; do
        source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
        target_path="$(readlink "$source_path")"
        if [[ "$target_path" = /* ]]; then
            source_path="$target_path"
        else
            source_path="$source_dir/$target_path"
        fi
    done

    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

detect_dotfiles_repo_root() {
    local script_path=""
    local script_dir=""

    script_path="$(resolve_script_path)"
    script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"

    if git -C "$script_dir/.." rev-parse --show-toplevel >/dev/null 2>&1; then
        git -C "$script_dir/.." rev-parse --show-toplevel
        return 0
    fi

    return 1
}

show_usage() {
    cat <<'EOF'
Usage:
  colorscheme <name>
  colorscheme --current
  colorscheme --list
  colorscheme --help

Options:
  -c, --current     Show current theme values only
  -l, --list        Show built-in theme presets only
  -h, --help        Show this help message

Note:
  Names not in the preset list are passed through directly to each tool.
  Use `colorscheme -- "<raw-name>"` if the theme name starts with `-`.
EOF
}

get_ghostty_theme() {
    if [ -f "$ghostty_config" ]; then
        grep -E '^theme\s*=' "$ghostty_config" | "$SED_BIN" -E 's/^theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_helix_theme() {
    if [ -f "$helix_config" ]; then
        grep -E '^theme\s*=' "$helix_config" | "$SED_BIN" -E 's/^theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_zellij_theme() {
    if [ -f "$zellij_config" ]; then
        grep -E '^theme\s' "$zellij_config" | "$SED_BIN" -E 's/^theme\s+"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_btop_theme() {
    if [ -f "$btop_config" ]; then
        grep -E '^color_theme\s*=' "$btop_config" | "$SED_BIN" -E 's/^color_theme\s*=\s*"?([^"]*)"?\s*$/\1/' | head -1
    fi
}

get_bat_theme() {
    if [ -f "$bat_config" ]; then
        "$SED_BIN" -n -E 's/^--theme="?([^"]+)"?$/\1/p' "$bat_config" | head -1
    fi
}

get_delta_theme() {
    if [ -f "$gitconfig" ]; then
        awk '
            $0 == "[delta]" { in_delta=1; next }
            /^\[/ { in_delta=0 }
            in_delta && /^[[:space:]]+syntax-theme[[:space:]]*=/ {
                sub(/^[[:space:]]+syntax-theme[[:space:]]*=[[:space:]]*/, "", $0)
                print
                exit
            }
        ' "$gitconfig"
    fi
}

get_delta_feature() {
    if [ -f "$gitconfig" ]; then
        awk '
            $0 == "[delta]" { in_delta=1; next }
            /^\[/ { in_delta=0 }
            in_delta && /^[[:space:]]+features[[:space:]]*=/ {
                sub(/^[[:space:]]+features[[:space:]]*=[[:space:]]*/, "", $0)
                print
                exit
            }
        ' "$gitconfig"
    fi
}

get_delta_display_theme() {
    local feature=""
    feature="$(get_delta_feature)"
    if [ -n "$feature" ]; then
        printf '%s\n' "$feature"
    else
        get_delta_theme
    fi
}

bat_has_theme() {
    local theme="$1"
    if ! command -v bat &>/dev/null; then
        return 1
    fi
    bat --list-themes --paging=never --color=never 2>/dev/null | grep -Fx "$theme" >/dev/null
}

ensure_bat_theme_available() {
    local theme="$1"
    local theme_file=""

    if [ "$theme" = "-" ]; then
        return 0
    fi

    if bat_has_theme "$theme"; then
        return 0
    fi

    if ! command -v bat &>/dev/null; then
        return 0
    fi

    theme_file="$config_home/bat/themes/$theme.tmTheme"
    if [ ! -f "$theme_file" ]; then
        return 0
    fi

    info "Building bat theme cache for $theme..."
    if ! bat cache --build >/dev/null 2>&1; then
        error "failed to build bat cache for theme: $theme"
        return 1
    fi

    if ! bat_has_theme "$theme"; then
        error "bat theme still unavailable after cache build: $theme"
        return 1
    fi

    success "Bat theme cache updated: $theme"
}

print_current_theme() {
    local label="$1"
    local value="$2"
    printf '  %-8s: %s\n' "$label" "${value:-not set}"
}

print_change() {
    local label="$1"
    local old_value="$2"
    local new_value="$3"
    success "$label: ${old_value:-not set} -> ${new_value:-not set}"
}

print_unchanged_warning() {
    local label="$1"
    local current_value="$2"
    local reason="$3"
    warn "$label: ${current_value:-not set} (unchanged, $reason)"
}

reload_ghostty_if_running() {
    local reload_result=""

    if [ "$(uname -s)" != "Darwin" ]; then
        return 0
    fi

    if ! command -v osascript &>/dev/null; then
        return 0
    fi

    # 不能依赖 pgrep 判断 GUI App 是否在运行：
    # Ghostty 的实际进程名可能因宿主形态或大小写差异而变化，容易误判。
    # 这里改用 macOS 原生 AppleScript 查询应用进程，再直接触发 `reload_config`。
    if reload_result="$(osascript 2>/dev/null <<'EOF'
tell application "System Events"
    set ghostty_running to (exists application process "Ghostty") or (exists application process "ghostty")
end tell

if not ghostty_running then
    return "not-running"
end if

using terms from application "Ghostty"
    tell application "Ghostty"
        if (count of every terminal) is 0 then
            return "no-terminals"
        end if

        perform action "reload_config" on first terminal
        return "reloaded"
    end tell
end using terms from
EOF
)"; then
        case "$reload_result" in
            reloaded)
                success "Ghostty config reloaded automatically"
                ;;
            not-running)
                info "Ghostty is not running; the new theme will apply on next launch."
                ;;
            no-terminals)
                warn "Ghostty is running without open terminals; reload skipped"
                ;;
            *)
                warn "Ghostty auto-reload returned an unexpected result: $reload_result"
                ;;
        esac
    else
        warn "Ghostty auto-reload failed; press Cmd + Shift + , manually."
    fi
}

# Show current theme from config files
show_current() {
    print_heading "Current theme:"
    print_current_theme "Ghostty" "$(get_ghostty_theme)"
    print_current_theme "Helix" "$(get_helix_theme)"
    print_current_theme "Zellij" "$(get_zellij_theme)"
    print_current_theme "Btop" "$(get_btop_theme)"
    print_current_theme "Bat" "$(get_bat_theme)"
    print_current_theme "Delta" "$(get_delta_display_theme)"
}

# List available themes
list_themes() {
    print_heading "Available themes:"
    for entry in "${THEMES[@]}"; do
        IFS='|' read -r name _ _ _ <<<"$entry"
        printf '  %s\n' "$name"
    done
}

show_overview() {
    show_current
    printf '\n'
    list_themes
    printf '\n'
    show_usage
}

# Lookup theme name for a specific tool.
# $1 = shortname, $2 = field index (1=ghostty, 2=helix, 3=zellij, 4=btop, 5=bat)
lookup_theme() {
    local name="$1" field="$2"
    for entry in "${THEMES[@]}"; do
        IFS='|' read -r entry_name ghostty helix zellij btop bat <<< "$entry"
        if [ "$entry_name" = "$name" ]; then
            local values=("$entry_name" "$ghostty" "$helix" "$zellij" "$btop" "$bat")
            local result="${values[$field]}"
            # '=' means same as shortname
            if [ "$result" = "=" ]; then
                echo "$name"
            else
                echo "$result"
            fi
            return
        fi
    done
    # Not found in registry, passthrough as-is
    echo "$name"
}

parse_args() {
    local arg=""

    colorscheme=""
    mode="apply"

    if [ "$#" -eq 0 ]; then
        mode="overview"
        return 0
    fi

    while [ "$#" -gt 0 ]; do
        arg="$1"
        case "$arg" in
            -h|--help)
                mode="help"
                shift
                ;;
            -l|--list)
                mode="list"
                shift
                ;;
            -c|--current)
                mode="current"
                shift
                ;;
            --)
                shift
                if [ "$#" -ne 1 ]; then
                    error "Expected exactly one theme name after '--'."
                    return 1
                fi
                colorscheme="$1"
                shift
                break
                ;;
            -*)
                error "Unknown option: $arg"
                return 1
                ;;
            *)
                if [ -n "$colorscheme" ]; then
                    error "Only one theme name can be provided."
                    return 1
                fi
                colorscheme="$arg"
                shift
                ;;
        esac

        if [ "$mode" != "apply" ] && [ "$#" -gt 0 ]; then
            error "Option '$arg' does not accept additional arguments."
            return 1
        fi
    done

    if [ "$mode" != "apply" ]; then
        return 0
    fi

    if [ -z "$colorscheme" ]; then
        error "Missing theme name."
        return 1
    fi

    return 0
}

ghostty_cs_change() {
    local old_theme=""
    if [ ! -f "$ghostty_config" ]; then
        error "ghostty config not found: $ghostty_config"
        return 1
    fi

    old_theme="$(get_ghostty_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 1)
    "$SED_BIN" -i -E "s/^theme\s*=.*/theme = \"$theme\"/" "$ghostty_config"
    print_change "Ghostty theme" "$old_theme" "$theme"
}

helix_cs_change() {
    local old_theme=""
    if [ ! -f "$helix_config" ]; then
        error "helix config not found: $helix_config"
        return 1
    fi

    old_theme="$(get_helix_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 2)
    "$SED_BIN" -i -E "s/^theme\s*=.*/theme = \"$theme\"/" "$helix_config"
    print_change "Helix theme" "$old_theme" "$theme"
}

zellij_cs_change() {
    local old_theme=""
    if [ ! -f "$zellij_config" ]; then
        error "zellij config not found: $zellij_config"
        return 1
    fi

    old_theme="$(get_zellij_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 3)
    "$SED_BIN" -i -E "s/^theme\s+\"[^\"]*\"/theme \"$theme\"/" "$zellij_config"
    print_change "Zellij theme" "$old_theme" "$theme"
}

btop_cs_change() {
    local old_theme=""
    if [ ! -f "$btop_config" ]; then
        error "btop config not found: $btop_config"
        return 1
    fi

    old_theme="$(get_btop_theme)"
    local theme
    theme=$(lookup_theme "$colorscheme" 4)
    "$SED_BIN" -i -E "s/^color_theme\s*=.*/color_theme = \"$theme\"/" "$btop_config"
    print_change "Btop theme" "$old_theme" "$theme"
}

bat_cs_change() {
    local old_theme=""
    local theme
    old_theme="$(get_bat_theme)"
    theme=$(lookup_theme "$colorscheme" 5)
    if [ "$theme" = "-" ]; then
        print_unchanged_warning "Bat theme" "$old_theme" "preset unsupported"
        return 0
    fi
    if [ ! -f "$bat_config" ]; then
        error "bat config not found: $bat_config"
        return 1
    fi
    ensure_bat_theme_available "$theme"
    if grep -Eq '^--theme=' "$bat_config"; then
        "$SED_BIN" -i -E 's/^--theme=.*/--theme="'"$theme"'"/' "$bat_config"
    elif grep -Eq '^#--theme=' "$bat_config"; then
        "$SED_BIN" -i -E 's/^#--theme=.*/--theme="'"$theme"'"/' "$bat_config"
    else
        printf '\n--theme="%s"\n' "$theme" >> "$bat_config"
    fi
    print_change "Bat theme" "$old_theme" "$theme"
}

delta_cs_change() {
    local old_theme=""
    local new_theme=""
    local syntax_theme=""
    local delta_feature=""
    if [ ! -f "$gitconfig" ]; then
        error "gitconfig not found: $gitconfig"
        return 1
    fi

    old_theme="$(get_delta_display_theme)"
    syntax_theme=$(lookup_theme "$colorscheme" 5)
    if [ "$syntax_theme" = "-" ]; then
        print_unchanged_warning "Delta theme" "$old_theme" "preset unsupported"
        return 0
    fi

    case "$colorscheme" in
        tokyonight)
            # Delta cannot consume Bat's custom Tokyo Night syntect theme directly.
            # Use the official Tokyo Night Delta feature instead.
            syntax_theme="Dracula"
            delta_feature="tokyonight-moon"
            ;;
        rose-pine)
            # Delta also cannot reuse Bat's custom Rose Pine syntect theme directly.
            # Keep syntax-theme on a safe built-in fallback and switch to a custom
            # Delta feature that recreates the Rose Pine diff palette.
            syntax_theme="Dracula"
            delta_feature="rose-pine"
            ;;
    esac

    "$SED_BIN" -i -E '/^\[delta\]/,/^\[/ s/^(\s+)syntax-theme\s*=.*/\1syntax-theme = '"$syntax_theme"'/' "$gitconfig"

    if [ -n "$delta_feature" ]; then
        git config --file="$gitconfig" delta.features "$delta_feature"
        new_theme="$delta_feature"
    else
        git config --file="$gitconfig" --unset-all delta.features >/dev/null 2>&1 || true
        new_theme="$syntax_theme"
    fi

    print_change "Delta theme" "$old_theme" "$new_theme"
}

main() {
    if dotfiles_repo_root="$(detect_dotfiles_repo_root)"; then
        :
    else
        dotfiles_repo_root=""
    fi

    parse_args "$@" || {
        printf '\n'
        show_usage
        exit 1
    }

    case "$mode" in
        overview)
            show_overview
            return 0
            ;;
        help)
            show_usage
            return 0
            ;;
        current)
            show_current
            return 0
            ;;
        list)
            list_themes
            return 0
            ;;
    esac

    ghostty_cs_change
    helix_cs_change
    zellij_cs_change
    btop_cs_change
    bat_cs_change
    delta_cs_change

    # --- Git Clean Filter Integration ---
    # After modifying files, run git add to trigger the clean filter.
    # This keeps 'git status' clean by syncing the index with the masked default values.
    if [ -n "$dotfiles_repo_root" ]; then
        # We must use relative paths within the repo for 'git add' to work reliably
        # even when the files are symlinked to ~/.config
        git -C "$dotfiles_repo_root" add \
            ghostty/dot-config/ghostty/config \
            helix/dot-config/helix/config.toml \
            zellij/dot-config/zellij/config.kdl \
            btop/dot-config/btop/btop.conf \
            bat/dot-config/bat/config \
            git/dot-config/git/config 2>/dev/null || true
    fi

    reload_ghostty_if_running
}

main "$@"
