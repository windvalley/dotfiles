#!/bin/bash

set -euo pipefail

# 允许该脚本独立运行；如果是从 install.sh 调用，则复用外层的彩色日志函数。
if ! declare -f info >/dev/null 2>&1; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  BLUE='\033[0;34m'
  YELLOW='\033[1;33m'
  NC='\033[0m'
  info() { echo -e "${BLUE}[INFO]${NC} $1"; }
  success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
  warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
  error() { echo -e "${RED}[ERROR]${NC} $1"; }
fi

show_help() {
  cat <<'EOF'
Usage:
  configure-shottr-hotkeys [--force] [--dry-run]

Options:
  --force     Overwrite existing Shottr global hotkeys
  --dry-run   Print the changes without writing preferences
  -h, --help  Show this help message
EOF
}

hotkey_label() {
  case "$1" in
  KeyboardShortcuts_fullscreen) printf '%s' 'Fullscreen screenshot (Shift+Cmd+1)' ;;
  KeyboardShortcuts_area) printf '%s' 'Area screenshot (Shift+Cmd+2)' ;;
  KeyboardShortcuts_anyWindow) printf '%s' 'Any window screenshot (Shift+Cmd+A)' ;;
  KeyboardShortcuts_scrolling) printf '%s' 'Scrolling screenshot (Shift+Cmd+S)' ;;
  *)
    error "Unknown Shottr hotkey key: $1"
    exit 1
    ;;
  esac
}

hotkey_value() {
  # Shottr 使用 Carbon key code + modifier mask 保存全局热键。
  # 768 = Shift + Command；18/19/0/1 分别对应 1/2/A/S。
  case "$1" in
  KeyboardShortcuts_fullscreen) printf '%s' '{"carbonKeyCode":18,"carbonModifiers":768}' ;;
  KeyboardShortcuts_area) printf '%s' '{"carbonKeyCode":19,"carbonModifiers":768}' ;;
  KeyboardShortcuts_anyWindow) printf '%s' '{"carbonKeyCode":0,"carbonModifiers":768}' ;;
  KeyboardShortcuts_scrolling) printf '%s' '{"carbonKeyCode":1,"carbonModifiers":768}' ;;
  *)
    error "Unknown Shottr hotkey key: $1"
    exit 1
    ;;
  esac
}

read_hotkey_value() {
  defaults read "$SHOTTR_DOMAIN" "$1" 2>/dev/null || true
}

FORCE=false
DRY_RUN=false

while [[ "$#" -gt 0 ]]; do
  case "$1" in
  --force) FORCE=true ;;
  --dry-run) DRY_RUN=true ;;
  -h | --help)
    show_help
    exit 0
    ;;
  *)
    error "Unknown parameter: $1"
    exit 1
    ;;
  esac
  shift
done

if [ "$(uname -s)" != "Darwin" ]; then
  error "Shottr hotkey setup is only supported on macOS."
  exit 1
fi

SHOTTR_DOMAIN="cc.ffitch.shottr"
HOTKEY_KEYS=(
  KeyboardShortcuts_fullscreen
  KeyboardShortcuts_area
  KeyboardShortcuts_anyWindow
  KeyboardShortcuts_scrolling
)

if [ ! -d "/Applications/Shottr.app" ] && [ ! -d "$HOME/Applications/Shottr.app" ]; then
  warn "Shottr.app was not found in /Applications. Preferences will still be written for future use."
fi

updated_count=0
skipped_count=0

for hotkey_key in "${HOTKEY_KEYS[@]}"; do
  current_value="$(read_hotkey_value "$hotkey_key")"
  target_value="$(hotkey_value "$hotkey_key")"
  label="$(hotkey_label "$hotkey_key")"

  if [ "$current_value" = "$target_value" ]; then
    info "$label is already configured."
    continue
  fi

  if [ -n "$current_value" ] && [ "$current_value" != "0" ] && [ "$FORCE" = false ]; then
    warn "$label already has a custom Shottr value. Re-run with --force to overwrite it."
    skipped_count=$((skipped_count + 1))
    continue
  fi

  if [ "$DRY_RUN" = true ]; then
    info "Would set $label"
  else
    defaults write "$SHOTTR_DOMAIN" "$hotkey_key" -string "$target_value"
    info "Configured $label"
  fi

  updated_count=$((updated_count + 1))
done

if [ "$DRY_RUN" = true ]; then
  success "Shottr hotkey dry run complete."
  exit 0
fi

if [ "$updated_count" -gt 0 ]; then
  success "Shottr hotkeys updated."
else
  success "No Shottr hotkey changes were needed."
fi

if [ "$skipped_count" -gt 0 ]; then
  warn "Skipped $skipped_count existing Shottr hotkey setting(s) to avoid overwriting custom preferences."
fi

if pgrep -x "Shottr" >/dev/null 2>&1; then
  warn "Shottr is currently running. Restart it once so the new hotkeys take effect."
fi
