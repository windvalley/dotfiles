#!/bin/bash
# audio-volume
#
# Requirements:
#   brew install switchaudio-osx
#
# Only for MacOS.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

usage() {
    local exit_code="${1:-1}"

    cat <<'EOF'
Usage:
  audio-volume <1-100>
  audio-volume -p | --print
  audio-volume -n | --next
  audio-volume -i <device_id>

Options:
  <1-100>           Set output volume
  -p, --print       Print all audio devices
  -n, --next        Switch to the next audio device
  -i <device_id>    Switch to the given audio device
EOF

    exit "$exit_code"
}

if ! command -v SwitchAudioSource &>/dev/null; then
    error "SwitchAudioSource is required. Please install it with 'brew install switchaudio-osx'."
    exit 1
fi

value="${1:-}"
flag_value="${2:-}"

set_volume() {
    local volume_value="$1"
    osascript -e "set volume output volume $volume_value"
}

print_audios() {
    SwitchAudioSource -a -f cli
}

switch_audio() {
    local device_id="$1"
    SwitchAudioSource -i "$device_id"
}

switch_next_audio() {
    SwitchAudioSource -n
}

main() {
    if [ "$#" -eq 0 ]; then
        usage 1
    fi

    case "$value" in
    -p|--print)
        if [ "$#" -ne 1 ]; then
            error "Print mode does not accept extra arguments."
            usage 1
        fi
        print_audios
        ;;
    -i)
        if [ "$#" -ne 2 ]; then
            error "Switch mode requires a device ID."
            usage 1
        fi
        if [[ "$flag_value" =~ ^[0-9]+$ ]]; then
            switch_audio "$flag_value"
            success "Audio output switched to device ID $flag_value."
            return
        fi
        error "device_id must be a number."
        usage 1
        ;;
    -n|--next)
        if [ "$#" -ne 1 ]; then
            error "Next mode does not accept extra arguments."
            usage 1
        fi
        switch_next_audio
        success "Switched to the next audio output device."
        ;;
    *)
        if ! [[ "$value" =~ ^[0-9]+$ ]]; then
            error "Unsupported argument: $value"
            usage 1
        fi
        if [ "$value" -lt 1 ] || [ "$value" -gt 100 ]; then
            error "Volume value must be in 1~100."
            usage 1
        fi
        if [ "$#" -ne 1 ]; then
            error "Volume mode does not accept extra arguments."
            usage 1
        fi
        set_volume "$value"
        success "Volume set to $value."
        ;;
    esac
}

main "$@"
