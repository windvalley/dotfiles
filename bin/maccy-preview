#!/bin/bash
# -----------------------------------------------------------------------------
# 剪贴板历史预览脚本 (供 fzf 调用)
# 该脚本通过读取 Maccy 的 SQLite 数据库，实现文本和图片的终端预览。
# -----------------------------------------------------------------------------

set -euo pipefail

# -- 彩色日志函数 (与项目 bin/ 脚本保持一致) --
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# -- 每次预览前清除残留的 Kitty Image Protocol 图片 --
# 保证从图片切回纯文本时，图片不会继续阴魂不散地悬浮在屏幕上
printf "\e_Ga=d;\e\\"

# -- 参数校验 --
if [ $# -lt 1 ]; then
    error "用法: $0 <Z_PK_ID>"
    exit 1
fi

ID="$1"

# 防御性校验：ID 必须是正整数，防止 SQL 注入
if ! [[ "$ID" =~ ^[0-9]+$ ]]; then
    error "无效的记录 ID: '$ID'（期望正整数）"
    exit 1
fi

MACCY_DB="$HOME/Library/Containers/org.p0deje.Maccy/Data/Library/Application Support/Maccy/Storage.sqlite"

if [ ! -f "$MACCY_DB" ]; then
    error "未找到 Maccy 数据库: $MACCY_DB"
    info "请确保已安装 Maccy 并至少运行过一次。"
    exit 1
fi

# -- 清理上一次可能残留的临时文件 --
TMP_IMG="/tmp/maccy_preview_img_${ID}.tiff"
rm -f "$TMP_IMG"

# -- 查询最佳内容类型 --
# 优先选择图片（png > tiff），如果没有则选文本
BEST_TYPE=$(sqlite3 "$MACCY_DB" "
SELECT ZTYPE
FROM ZHISTORYITEMCONTENT
WHERE ZITEM = $ID AND (ZTYPE = 'public.png' OR ZTYPE = 'public.tiff' OR ZTYPE = 'public.utf8-plain-text')
ORDER BY
  CASE ZTYPE
    WHEN 'public.png' THEN 1
    WHEN 'public.tiff' THEN 2
    WHEN 'public.utf8-plain-text' THEN 3
    ELSE 4
  END
LIMIT 1;
")

if [ -z "$BEST_TYPE" ]; then
    warn "该条目没有可预览的内容。"
    exit 0
fi

if [[ "$BEST_TYPE" == "public.png" || "$BEST_TYPE" == "public.tiff" ]]; then
    # -- 处理图片预览 --
    sqlite3 "$MACCY_DB" "SELECT writefile('$TMP_IMG', ZVALUE) FROM ZHISTORYITEMCONTENT WHERE ZITEM = $ID AND ZTYPE = '$BEST_TYPE' LIMIT 1;" >/dev/null 2>&1

    if [ -f "$TMP_IMG" ]; then
        if command -v chafa >/dev/null 2>&1; then
            # 兼容性侦测：
            # Ghostty 仅支持 Kitty 图像协议，不支持 Sixel。
            # Zellij 会吞没 Kitty 协议，目前仅支持 Sixel。
            # 因此，只有在非 Zellij 环境下才能输出高清 Kitty 图片，Zellij 下只能用字符画(Symbols)兜底。
            if [ -n "${ZELLIJ:-}" ]; then
                chafa -f symbols --size="${FZF_PREVIEW_COLUMNS:-80}x${FZF_PREVIEW_LINES:-40}" "$TMP_IMG"
            else
                chafa -f kitty --size="${FZF_PREVIEW_COLUMNS:-80}x${FZF_PREVIEW_LINES:-40}" "$TMP_IMG"
            fi
        else
            info "🖼️ [图片类型: $BEST_TYPE]"
            warn "提示: 安装 'chafa' (brew install chafa) 可启用终端图片预览。"
        fi
        # 清理临时文件
        rm -f "$TMP_IMG"
    else
        error "无法提取图片用于预览。"
    fi
else
    # -- 处理纯文本预览 --
    sqlite3 "$MACCY_DB" "SELECT ZVALUE FROM ZHISTORYITEMCONTENT WHERE ZITEM = $ID AND ZTYPE = 'public.utf8-plain-text' LIMIT 1;"
fi
