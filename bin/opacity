#!/bin/bash
# opacity
#
# Ghostty terminal background transparency adjustment.
#
# Requirements:
#   brew install gnu-sed

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Check for gsed (GNU sed)
if command -v gsed &>/dev/null; then
    SED_BIN="gsed"
elif command -v sed &>/dev/null; then
    SED_BIN="sed"
else
    error "sed not found"
    exit 1
fi

to_opacity=${1:-}

config_home=${XDG_CONFIG_HOME:-"$HOME/.config"}
ghostty_config="$config_home/ghostty/config"
dotfiles_repo_root=""

resolve_script_path() {
    local source_path="${BASH_SOURCE[0]}"
    local source_dir=""
    local target_path=""

    if [[ "$source_path" != */* ]]; then
        source_path="$(command -v "$source_path")"
    fi

    while [ -L "$source_path" ]; do
        source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
        target_path="$(readlink "$source_path")"
        if [[ "$target_path" = /* ]]; then
            source_path="$target_path"
        else
            source_path="$source_dir/$target_path"
        fi
    done

    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

detect_dotfiles_repo_root() {
    local script_path=""
    local script_dir=""

    script_path="$(resolve_script_path)"
    script_dir="$(cd -P "$(dirname "$script_path")" && pwd)"

    if git -C "$script_dir/.." rev-parse --show-toplevel >/dev/null 2>&1; then
        git -C "$script_dir/.." rev-parse --show-toplevel
        return 0
    fi

    return 1
}

sync_ghostty_config_to_index() {
    if [ -n "$dotfiles_repo_root" ]; then
        git -C "$dotfiles_repo_root" add ghostty/dot-config/ghostty/config 2>/dev/null || true
    fi
}

get_current_opacity() {
    if [ -f "$ghostty_config" ]; then
        grep -E '^background-opacity\s*=' "$ghostty_config" | "$SED_BIN" -E 's/^background-opacity\s*=\s*//' | head -1
    fi
}

if [ "$#" -ne 1 ]; then
    current="$(get_current_opacity)"
    printf 'Current opacity: %s\n' "${current:-1.0 (default, fully opaque)}"
    printf 'Usage: opacity <0.0-1.0>\n'
    exit 0
fi

if ! echo "$to_opacity" | grep -qE '^(0(\.[0-9]+)?|1(\.0+)?|\.[0-9]+)$'; then
    error "opacity must be between 0 and 1"
    exit 1
fi


change_ghostty_opacity() {
    if [ ! -f "$ghostty_config" ]; then
        error "ghostty config not found: $ghostty_config"
        return 1
    fi

    if grep -qE '^background-opacity\s*=' "$ghostty_config"; then
        "$SED_BIN" -i -E "s/^background-opacity\s*=\s*.*/background-opacity = $to_opacity/" "$ghostty_config"
    else
        printf '\nbackground-opacity = %s\n' "$to_opacity" >> "$ghostty_config"
    fi
}

old_opacity="$(get_current_opacity)"
change_ghostty_opacity
if dotfiles_repo_root="$(detect_dotfiles_repo_root)"; then
    sync_ghostty_config_to_index
fi
success "Ghostty opacity: ${old_opacity:-not set} -> $to_opacity"
