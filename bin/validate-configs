#!/bin/bash
# validate-configs
#
# 验证 dotfiles 配置文件的语法和完整性
# 用法: validate-configs [fish|git|zellij|helix|mise|ghostty|karabiner|aichat|go-musicfox|all]

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[✓]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[✗]${NC} $1"; }

record_error() {
    error "$1"
    ERRORS=$((ERRORS + 1))
}

# 尝试多种方式获取 dotfiles 目录
# 1. 环境变量（优先级最高）
# 2. 从脚本位置推断（bin/validate-configs -> dotfiles/）
# 3. 从 git 仓库位置推断
if [ -n "${DOTFILES_DIR:-}" ]; then
    : # 使用环境变量
elif [ -d "$(dirname "${BASH_SOURCE[0]}")/../.git" ]; then
    DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
elif git -C "$(dirname "${BASH_SOURCE[0]}")/.." rev-parse --is-inside-work-tree &>/dev/null; then
    DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
else
    # 默认值
    DOTFILES_DIR="$HOME/dotfiles"
fi
ERRORS=0

# Python TOML 验证脚本
validate_toml_file() {
    local file="$1"
    if [ ! -f "$file" ]; then
        return 0
    fi

    if ! command -v python3 &>/dev/null; then
        return 2
    fi
    
    python3 -c "
import sys
import warnings
warnings.filterwarnings('ignore')

try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        print('TOML 验证跳过: Python < 3.11 且未安装 tomli 库')
        sys.exit(0)  # Python < 3.11 且无 tomli，跳过验证

try:
    with open('$file', 'rb') as f:
        tomllib.load(f)
except Exception as e:
    print(f'$file: TOML 语法错误: {e}')
    sys.exit(1)
" || return 1
    return 0
}

validate_yaml_file() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return 0
    fi

    if ! command -v ruby &>/dev/null; then
        return 2
    fi

    ruby -e '
require "yaml"
YAML.load_file(ARGV[0])
' "$file" >/dev/null 2>&1 || return 1

    return 0
}

strip_ansi_escapes() {
    perl -pe 's/\e\[[0-9;]*[[:alpha:]]//g'
}

helix_health_has_external_tools() {
    awk '
        /Configured language servers:/ { section="lsp"; next }
        /Configured formatter:/ { section="formatter"; next }
        /Configured debug adapter:/ { section=""; next }
        /Tree-sitter parser:/ { exit }
        section == "" { next }
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
            if (line != "" && line != "None") {
                found = 1
                exit
            }
        }
        END { exit(found ? 0 : 1) }
    '
}

helix_health_missing_dependencies() {
    awk '
        /Configured language servers:/ { section="LSP"; next }
        /Configured formatter:/ { section="Formatter"; next }
        /Configured debug adapter:/ { section=""; next }
        /Tree-sitter parser:/ { exit }
        section == "" { next }
        {
            line = $0
            sub(/^[[:space:]]*/, "", line)
            if (line ~ /^✘[[:space:]]+/) {
                sub(/^✘[[:space:]]+/, "", line)
                issues = issues ? issues "; " section ": " line : section ": " line
            }
        }
        END {
            if (issues != "") {
                print issues
            }
        }
    '
}

run_helix_health() {
    local helix_config="$1"
    shift
    local mise_config="$DOTFILES_DIR/mise/dot-config/mise/config.toml"
    local trusted_paths="$mise_config"

    if [ -f "$HOME/.config/mise/config.toml" ]; then
        trusted_paths="$trusted_paths:$HOME/.config/mise/config.toml"
    fi

    # Helix 的健康检查依赖 PATH 中的外部工具。这里优先通过仓库声明的 mise 配置
    # 构造运行环境，避免 validate-configs 在 Bash 环境下误报 “工具缺失”，而实际 Fish 会话中正常。
    if command -v mise &>/dev/null && [ -f "$mise_config" ]; then
        env \
            MISE_GLOBAL_CONFIG_FILE="$mise_config" \
            MISE_TRUSTED_CONFIG_PATHS="$trusted_paths" \
            MISE_AUTO_INSTALL=0 \
            mise exec --no-prepare -- hx -c "$helix_config" "$@"
        return $?
    fi

    hx -c "$helix_config" "$@"
}

aichat_config_declares_local_llm() {
    local aichat_config="$1"
    grep -Eq '^[[:space:]]*name:[[:space:]]*local-llm[[:space:]]*$' "$aichat_config"
}

aichat_config_local_model_count() {
    local aichat_config="$1"

    awk '
        /^[[:space:]]*-[[:space:]]*type:/ {
            if (matched && in_models) {
                in_models = 0
            }
            next
        }
        /^[[:space:]]*name:[[:space:]]*local-llm[[:space:]]*$/ {
            matched = 1
            next
        }
        matched && /^[[:space:]]*models:[[:space:]]*$/ {
            in_models = 1
            next
        }
        matched && in_models && /^[[:space:]]*-[[:space:]]*name:[[:space:]]*/ {
            count++
            next
        }
        matched && in_models && /^[[:space:]]*[A-Za-z_-]+:/ {
            in_models = 0
        }
        END {
            print count + 0
        }
    ' "$aichat_config"
}

local_ai_expectation_summary() {
    local -a reasons=()
    local joined=""
    local reason=""

    case ",${AI_CHAT_BACKENDS:-}," in
        *,q,*)
            reasons+=("AI_CHAT_BACKENDS 包含 q")
            ;;
    esac

    if [[ "${AICHAT_MODEL:-}" == local-llm:* ]]; then
        reasons+=("AICHAT_MODEL 使用 local-llm")
    fi

    if [ -n "${AI_LOCAL_MODEL:-}" ]; then
        reasons+=("已设置 AI_LOCAL_MODEL")
    fi

    [ "${#reasons[@]}" -gt 0 ] || return 1

    for reason in "${reasons[@]}"; do
        if [ -n "$joined" ]; then
            joined="${joined}；${reason}"
        else
            joined="$reason"
        fi
    done

    printf '%s\n' "$joined"
}

validate_ghostty_file_static() {
    local ghostty_file="$1"

    if ! command -v python3 &>/dev/null; then
        return 2
    fi

    python3 - "$ghostty_file" <<'PY'
import re
import sys
from pathlib import Path


ASSIGNMENT_RE = re.compile(r"^[a-z0-9-]+$")
QUOTED_VALUE_RE = re.compile(r'^"(?:[^"\\]|\\.)*"$')


def parse_value(raw_value, path, lineno):
    value = raw_value.strip()
    if not value:
        return "", False
    if value.startswith('"'):
        if not QUOTED_VALUE_RE.fullmatch(value):
            raise ValueError(f"{path}:{lineno}: 双引号未闭合: {raw_value.strip()}")
        return value[1:-1], True
    return value, False


def validate_file(path, visited, stack, errors):
    resolved = path.resolve()
    if resolved in stack:
        errors.append(f"{resolved}: 检测到 config-file 循环引用")
        return
    if resolved in visited:
        return
    if not resolved.is_file():
        errors.append(f"{resolved}: 配置文件不存在")
        return

    visited.add(resolved)
    stack.add(resolved)

    for lineno, raw_line in enumerate(resolved.read_text(encoding="utf-8").splitlines(), start=1):
        stripped = raw_line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if "=" not in stripped:
            errors.append(f"{resolved}:{lineno}: 缺少 '=': {stripped}")
            continue

        key_part, value_part = stripped.split("=", 1)
        key = key_part.strip()
        if not key:
            errors.append(f"{resolved}:{lineno}: 配置键为空")
            continue
        if not ASSIGNMENT_RE.fullmatch(key):
            errors.append(f"{resolved}:{lineno}: 非法配置键: {key}")
            continue

        try:
            value, quoted = parse_value(value_part, resolved, lineno)
        except ValueError as exc:
            errors.append(str(exc))
            continue

        if key != "config-file":
            continue

        include_path = value
        optional = False
        if include_path and not quoted and include_path.startswith("?"):
            optional = True
            include_path = include_path[1:]

        if not include_path:
            continue

        nested = Path(include_path).expanduser()
        if not nested.is_absolute():
            nested = (resolved.parent / nested).resolve()

        if nested.exists():
            validate_file(nested, visited, stack, errors)
        elif not optional:
            errors.append(f"{resolved}:{lineno}: 引用的配置文件不存在: {nested}")

    stack.remove(resolved)


errors = []
validate_file(Path(sys.argv[1]), set(), set(), errors)
if errors:
    for item in errors:
        print(item)
    sys.exit(1)
PY
}

# 验证 Fish 配置
validate_fish() {
    info "验证 Fish 配置..."
    local fish_dir="$DOTFILES_DIR/fish/dot-config/fish"
    local fish_file=""
    local fish_failures=0
    local fish_files=()

    if [ ! -d "$fish_dir" ]; then
        record_error "Fish 配置目录不存在: $fish_dir"
        return 0
    fi

    shopt -s nullglob
    fish_files=(
        "$fish_dir/config.fish"
        "$fish_dir"/functions/*.fish
        "$fish_dir"/conf.d/*.fish
        "$fish_dir"/completions/*.fish
    )
    shopt -u nullglob

    if [ "${#fish_files[@]}" -eq 0 ]; then
        record_error "Fish 配置目录为空: $fish_dir"
        return 0
    fi

    # Fish 本身是唯一可靠的语法校验器；缺失时必须让验证失败，避免“未验证却通过”。
    if ! command -v fish &>/dev/null; then
        record_error "Fish 未安装，无法可靠验证 Fish 语法"
        return 0
    fi

    for fish_file in "${fish_files[@]}"; do
        if fish -n "$fish_file" 2>/dev/null; then
            success "Fish 语法正确: $(basename "$fish_file")"
        else
            error "Fish 语法错误: $fish_file"
            fish_failures=$((fish_failures + 1))
        fi
    done

    # 仅做 fish -n 语法检查无法覆盖启动期逻辑；这里强制模拟 zsh -> fish 的常见链路，
    # 及时发现诸如 `brew shellenv` 输出错误 shell 语法导致的启动异常。
    if [ "$fish_failures" -eq 0 ] && command -v zsh &>/dev/null; then
        if env SHELL="$(command -v zsh)" fish -lc 'true' >/dev/null 2>&1; then
            success "Fish 启动链路正确 (zsh -> fish login shell)"
        else
            error "Fish 启动链路异常 (zsh -> fish login shell)"
            fish_failures=$((fish_failures + 1))
        fi
    fi

    if [ "$fish_failures" -gt 0 ]; then
        ERRORS=$((ERRORS + fish_failures))
    fi
}

# 验证 Git 配置
validate_git() {
    info "验证 Git 配置..."
    local git_config="$DOTFILES_DIR/git/dot-config/git/config"
    local git_delta_theme="$DOTFILES_DIR/git/dot-config/git/delta-theme.conf"
    local validate_home=""
    
    if [ ! -f "$git_config" ]; then
        error "Git 配置文件不存在: $git_config"
        return 1
    fi

    if [ ! -f "$git_delta_theme" ]; then
        error "Git Delta 主题配置文件不存在: $git_delta_theme"
        return 1
    fi
    
    # Git 配置格式检查
    if git config --file="$git_config" --list &>/dev/null; then
        success "Git 配置格式正确"
    else
        error "Git 配置存在格式错误"
        ERRORS=$((ERRORS + 1))
    fi

    if git config --file="$git_delta_theme" --list &>/dev/null; then
        success "Git Delta 主题配置格式正确"
    else
        error "Git Delta 主题配置存在格式错误"
        ERRORS=$((ERRORS + 1))
    fi

    # 使用临时 HOME 隔离本地私有配置，只验证仓库内主配置能否正确 include Delta 主题文件。
    validate_home="$(mktemp -d "${TMPDIR:-/tmp}/validate-git.XXXXXX")"
    if HOME="$validate_home" git config --includes --file="$git_config" --get delta.syntax-theme &>/dev/null; then
        success "Git 主配置可正确 include Delta 主题配置"
    else
        error "Git 主配置无法正确 include Delta 主题配置"
        ERRORS=$((ERRORS + 1))
    fi
    rm -rf "$validate_home"
}

# 验证 Zellij 配置
validate_zellij() {
    info "验证 Zellij 配置..."
    local zellij_config_dir="$DOTFILES_DIR/zellij/dot-config/zellij"
    local zellij_config="$zellij_config_dir/config.kdl"
    local layout_dir="$zellij_config_dir/layouts"
    local layout_file=""
    local layout_name=""
    local layout_files=()
    local layout_failures=0
    local parse_output=""

    if [ ! -f "$zellij_config" ]; then
        error "Zellij 配置文件不存在: $zellij_config"
        return 1
    fi

    if [ ! -d "$layout_dir" ]; then
        record_error "Zellij 布局目录不存在: $layout_dir"
        return 0
    fi

    shopt -s nullglob
    layout_files=("$layout_dir"/*.kdl)
    shopt -u nullglob

    if [ "${#layout_files[@]}" -eq 0 ]; then
        record_error "Zellij 布局目录为空: $layout_dir"
        return 0
    fi

    # Zellij 配置语义依赖其自身 KDL 解析器；缺失 CLI 时不能把“未验证”当成“通过”。
    if ! command -v zellij &>/dev/null; then
        record_error "Zellij 未安装，无法可靠验证配置"
        return 0
    fi

    if parse_output=$(zellij --config "$zellij_config" setup --check 2>&1 >/dev/null); then
        success "Zellij 配置语法正确 (KDL)"
    else
        error "Zellij 配置 KDL 语法错误:"
        echo "$parse_output" | sed 's/^/    /'
        ERRORS=$((ERRORS + 1))
    fi

    for layout_file in "${layout_files[@]}"; do
        layout_name="$(basename "$layout_file" .kdl)"

        if parse_output=$(zellij --config-dir "$zellij_config_dir" setup --dump-layout "$layout_name" 2>&1 >/dev/null); then
            success "Zellij 布局语法正确: $layout_name"
        else
            error "Zellij 布局语法错误: $layout_file"
            if [ -n "$parse_output" ]; then
                echo "$parse_output" | sed 's/^/    /'
            fi
            layout_failures=$((layout_failures + 1))
        fi
    done

    if [ "$layout_failures" -gt 0 ]; then
        ERRORS=$((ERRORS + layout_failures))
    fi
}

# 验证 Helix 配置
validate_helix() {
    info "验证 Helix 配置..."
    local helix_config="$DOTFILES_DIR/helix/dot-config/helix/config.toml"
    local helix_languages="$DOTFILES_DIR/helix/dot-config/helix/languages.toml"
    local clipboard_output=""
    local clipboard_provider=""
    local health_output=""
    local language_name=""
    local missing_dependencies=""
    local healthy_language_count=0
    local checked_language_count=0
    local missing_language_count=0
    local toml_status=0
    
    # 检查配置文件是否存在
    if [ ! -f "$helix_config" ]; then
        error "Helix 配置文件不存在: $helix_config"
        ERRORS=$((ERRORS + 1))
    else
        # 静态 TOML 检查
        if validate_toml_file "$helix_config"; then
            success "Helix 主配置语法正确 (TOML)"
        else
            toml_status=$?
            if [ "$toml_status" -eq 2 ]; then
                error "缺少 python3，无法执行 Helix 主配置 TOML 静态校验"
            else
                error "Helix 主配置语法错误"
            fi
            ERRORS=$((ERRORS + 1))
        fi
    fi
    
    if [ -f "$helix_languages" ]; then
         # 静态 TOML 检查
        if validate_toml_file "$helix_languages"; then
            success "Helix 语言配置语法正确 (TOML)"
        else
            toml_status=$?
            if [ "$toml_status" -eq 2 ]; then
                error "缺少 python3，无法执行 Helix 语言配置 TOML 静态校验"
            else
                error "Helix 语言配置语法错误"
            fi
            ERRORS=$((ERRORS + 1))
        fi
    fi
    
    # 如果 helix 已安装，运行健康检查
    if command -v hx &>/dev/null; then
        info "Helix 健康摘要:"

        if clipboard_output=$(run_helix_health "$helix_config" --health clipboard 2>/dev/null | strip_ansi_escapes); then
            clipboard_provider="$(printf '%s\n' "$clipboard_output" | sed -n '1p')"
            if [ -n "$clipboard_provider" ]; then
                success "$clipboard_provider"
            fi
        else
            warn "无法获取 Helix 剪贴板状态"
        fi

        if [ -f "$helix_languages" ]; then
            while IFS= read -r language_name; do
                [ -n "$language_name" ] || continue

                if ! health_output=$(run_helix_health "$helix_config" --health "$language_name" 2>/dev/null | strip_ansi_escapes); then
                    warn "无法获取 Helix 语言健康状态: $language_name"
                    continue
                fi

                if ! printf '%s\n' "$health_output" | helix_health_has_external_tools; then
                    continue
                fi

                checked_language_count=$((checked_language_count + 1))
                missing_dependencies="$(printf '%s\n' "$health_output" | helix_health_missing_dependencies)"

                if [ -n "$missing_dependencies" ]; then
                    warn "Helix 外部工具缺失 ($language_name): $missing_dependencies"
                    missing_language_count=$((missing_language_count + 1))
                else
                    healthy_language_count=$((healthy_language_count + 1))
                fi
            done < <(awk -F'"' '/^[[:space:]]*name[[:space:]]*=[[:space:]]*"/ { print $2 }' "$helix_languages")
        fi

        if [ "$checked_language_count" -eq 0 ]; then
            warn "未发现需要外部工具的 Helix 自定义语言"
        elif [ "$missing_language_count" -eq 0 ]; then
            success "Helix 外部工具检查通过: $checked_language_count 个自定义语言"
        else
            warn "Helix 外部工具部分缺失: $healthy_language_count/$checked_language_count 个自定义语言可用"
            info "如需单语言详情，可执行: hx -c $helix_config --health <language>"
        fi
    else
        warn "Helix 未安装，跳过健康检查"
    fi
}

# 验证 Mise 配置
validate_mise() {
    info "验证 Mise 配置..."
    local mise_config="$DOTFILES_DIR/mise/dot-config/mise/config.toml"
    local toml_status=0
    
    if [ ! -f "$mise_config" ]; then
        error "Mise 配置文件不存在: $mise_config"
        return 1
    fi

    # 静态 TOML 检查
    if validate_toml_file "$mise_config"; then
        success "Mise 配置语法正确 (TOML)"
    else
        toml_status=$?
        if [ "$toml_status" -eq 2 ]; then
            error "缺少 python3，无法执行 Mise TOML 静态校验"
        else
            error "Mise 配置语法错误"
        fi
        ERRORS=$((ERRORS + 1))
    fi
    
    if command -v mise &>/dev/null; then
        if mise ls &>/dev/null; then
            success "Mise 配置可正常读取"
        else
            warn "Mise 配置可能有警告（工具未安装不影响配置有效性）"
        fi
    else
        warn "Mise 未安装，跳过配置检查"
    fi
}

# 验证 Ghostty 配置
validate_ghostty() {
    info "验证 Ghostty 配置..."
    local ghostty_config="$DOTFILES_DIR/ghostty/dot-config/ghostty/config"
    local output=""
    local static_status=0
    
    if [ ! -f "$ghostty_config" ]; then
        error "Ghostty 配置文件不存在: $ghostty_config"
        return 1
    fi

    # 优先使用 ghostty CLI 进行验证
    if command -v ghostty &>/dev/null; then
        # 捕获输出，只显示错误信息
        if output=$(ghostty +validate-config --config-file="$ghostty_config" 2>&1); then
            success "Ghostty 配置验证通过 (CLI)"
        else
            error "Ghostty 配置验证失败:"
            echo "$output" | sed 's/^/    /' # 缩进输出
            ERRORS=$((ERRORS + 1))
        fi
    else
        warn "Ghostty CLI 未找到，执行离线静态语法检查..."
        if output=$(validate_ghostty_file_static "$ghostty_config" 2>&1); then
            success "Ghostty 配置语法正确 (离线静态检查)"
        else
            static_status=$?
            if [ "$static_status" -eq 2 ]; then
                output="缺少 python3，无法执行 Ghostty 离线静态校验"
            fi
            error "Ghostty 配置静态检查失败:"
            echo "$output" | sed 's/^/    /'
            ERRORS=$((ERRORS + 1))
        fi
    fi
}

# 验证 Karabiner 配置
validate_karabiner() {
    info "验证 Karabiner 配置..."
    local karabiner_config="$DOTFILES_DIR/karabiner/dot-config/karabiner/karabiner.json"
    
    if [ ! -f "$karabiner_config" ]; then
        error "Karabiner 配置文件不存在: $karabiner_config"
        return 1
    fi

    if ! command -v python3 &>/dev/null; then
        record_error "缺少 python3，无法执行 Karabiner JSON 静态校验"
        return 0
    fi

    # JSON 语法验证
    if python3 -m json.tool "$karabiner_config" > /dev/null 2>&1; then
        success "Karabiner 配置语法正确 (JSON)"
    else
        error "Karabiner 配置 JSON 语法错误"
        ERRORS=$((ERRORS + 1))
    fi
}

# 验证 AIChat / Ollama 配置
validate_aichat() {
    info "验证 AIChat 配置..."
    local aichat_dir="$DOTFILES_DIR/aichat/dot-config/aichat"
    local aichat_config="$aichat_dir/config.yaml"
    local aichat_runtime_env=()
    local local_ai_expectation=""
    local local_llm_declared=false
    local local_llm_config_model_count=0
    local local_llm_index_count=0
    local model_list=""
    local ollama_model_count=0
    local ollama_list_output=""
    local yaml_status=0

    if [ ! -f "$aichat_config" ]; then
        error "AIChat 配置文件不存在: $aichat_config"
        ERRORS=$((ERRORS + 1))
        return 1
    fi

    if validate_yaml_file "$aichat_config"; then
        success "AIChat 配置语法正确 (YAML)"
    else
        yaml_status=$?
        if [ "$yaml_status" -eq 2 ]; then
            record_error "缺少 Ruby，无法执行 AIChat YAML 静态校验"
        else
            record_error "AIChat 配置 YAML 语法错误"
        fi
        return 0
    fi

    aichat_runtime_env=(env -u AICHAT_MODEL -u AICHAT_CONFIG_DIR AICHAT_CONFIG_DIR="$aichat_dir")
    local_ai_expectation="$(local_ai_expectation_summary || true)"
    if aichat_config_declares_local_llm "$aichat_config"; then
        local_llm_declared=true
        local_llm_config_model_count="$(aichat_config_local_model_count "$aichat_config")"
    fi

    if command -v aichat &>/dev/null; then
        if "${aichat_runtime_env[@]}" aichat --info >/dev/null 2>&1; then
            success "AIChat 配置可正常读取"
        else
            error "AIChat 配置读取失败"
            ERRORS=$((ERRORS + 1))
            return 1
        fi

        if model_list=$("${aichat_runtime_env[@]}" aichat --list-models 2>/dev/null); then
            local_llm_index_count="$(printf '%s\n' "$model_list" | grep -c '^local-llm:' || true)"
            if [ "$local_llm_index_count" -gt 0 ]; then
                success "AIChat 已注册本地 Ollama provider (local-llm，索引中 $local_llm_index_count 个模型)"
            elif [ "$local_llm_declared" = true ]; then
                warn "AIChat 已声明 local-llm client，但当前模型索引中未注册本地模型；可执行 'aichat --sync-models'"
            else
                info "AIChat 当前未注册 local-llm provider"
            fi
        else
            warn "无法读取 AIChat 模型列表"
        fi
    else
        warn "AIChat 未安装，已跳过运行时配置检查，仅完成 YAML 静态校验"
        return 0
    fi

    if command -v ollama &>/dev/null; then
        if ollama_list_output=$(ollama list 2>/dev/null); then
            ollama_model_count="$(printf '%s\n' "$ollama_list_output" | awk 'NR > 1 && NF > 0 { count++ } END { print count + 0 }')"
            if [ "$ollama_model_count" -gt 0 ]; then
                success "Ollama 本地服务可访问 (已下载 $ollama_model_count 个模型)"
            elif [ -n "$local_ai_expectation" ]; then
                warn "Ollama 本地服务可访问，但尚未下载任何模型；当前环境启用了本地 AI 工作流（$local_ai_expectation）"
            else
                info "Ollama 本地服务可访问，但尚未下载任何模型"
            fi
        else
            if [ -n "$local_ai_expectation" ]; then
                warn "Ollama 已安装，但本地服务不可访问；当前环境启用了本地 AI 工作流（$local_ai_expectation）"
            elif [ "$local_llm_index_count" -gt 0 ] || [ "$local_llm_config_model_count" -gt 0 ]; then
                info "Ollama 已安装，但本地服务当前未运行；AIChat 已配置 local-llm，可按需执行 'brew services start ollama' 或手动运行 'ollama serve'"
            else
                info "Ollama 已安装，但本地服务当前未运行"
            fi
        fi
    else
        if [ -n "$local_ai_expectation" ]; then
            warn "Ollama 未安装；当前环境启用了本地 AI 工作流（$local_ai_expectation）"
        elif [ "$local_llm_index_count" -gt 0 ] || [ "$local_llm_config_model_count" -gt 0 ]; then
            info "Ollama 未安装；AIChat 已预留 local-llm 配置，若需本地模型可后续按需安装"
        else
            info "Ollama 未安装；本地模型后端当前处于未启用状态"
        fi
    fi
}

# 验证 go-musicfox 模板配置
validate_go_musicfox() {
    info "验证 go-musicfox 配置模板..."
    local musicfox_config="$DOTFILES_DIR/local/go-musicfox.config.toml.example"
    local toml_status=0

    if [ ! -f "$musicfox_config" ]; then
        record_error "go-musicfox 配置模板不存在: $musicfox_config"
        return 0
    fi

    if validate_toml_file "$musicfox_config"; then
        success "go-musicfox 配置模板语法正确 (TOML)"
    else
        toml_status=$?
        if [ "$toml_status" -eq 2 ]; then
            record_error "Python3 不可用，无法验证 go-musicfox 配置模板"
        else
            record_error "go-musicfox 配置模板存在 TOML 语法错误"
        fi
    fi
}

# 验证自定义脚本
validate_bin_scripts() {
    info "验证自定义脚本..."
    local bin_dir="$DOTFILES_DIR/bin"
    
    for script in "$bin_dir"/*; do
        if [ -f "$script" ] && [ -x "$script" ]; then
            local script_name
            script_name=$(basename "$script")
            # 检查 shebang
            if head -1 "$script" | grep -q "^#!/"; then
                success "$script_name - shebang 正确"
            else
                warn "$script_name - 缺少 shebang"
            fi
        fi
    done
}

# 主逻辑
main() {
    local target="${1:-all}"
    
    echo "========================================"
    echo "  Dotfiles 配置验证"
    echo "  目录: $DOTFILES_DIR"
    echo "========================================"
    echo
    
    case "$target" in
        fish)
            validate_fish
            ;;
        git)
            validate_git
            ;;
        zellij)
            validate_zellij
            ;;
        helix)
            validate_helix
            ;;
        mise)
            validate_mise
            ;;
        ghostty)
            validate_ghostty
            ;;
        karabiner)
            validate_karabiner
            ;;
        aichat)
            validate_aichat
            ;;
        go-musicfox)
            validate_go_musicfox
            ;;
        all)
            validate_fish
            validate_git
            validate_zellij
            validate_helix
            validate_mise
            validate_ghostty
            validate_karabiner
            validate_aichat
            validate_go_musicfox
            validate_bin_scripts
            ;;
        *)
            echo "用法: validate-configs [fish|git|zellij|helix|mise|ghostty|karabiner|aichat|go-musicfox|all]"
            exit 1
            ;;
    esac
    
    echo
    echo "========================================"
    if [ $ERRORS -eq 0 ]; then
        success "验证完成，未发现错误"
        exit 0
    else
        error "验证完成，发现 $ERRORS 个错误"
        exit 1
    fi
}

main "$@"
