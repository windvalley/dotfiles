#!/bin/bash
# Git clean filter for dotfiles local visual preference decoupling
# This filter restores tracked defaults when git reads selected files into the index,
# preventing local theme/font-size/opacity changes from dirtying the git working tree.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

file="${1:-}"

if [ -z "$file" ]; then
    error "Missing target file path."
    exit 1
fi

# Check for gsed (GNU sed) - macOS default sed doesn't support some -E features uniformly
if command -v gsed &>/dev/null; then
    SED_BIN="gsed"
else
    SED_BIN="sed"
fi

case "$file" in
    *ghostty/config)
        "$SED_BIN" -E \
            -e 's/^theme\s*=\s*".*"/theme = "Dracula"/' \
            -e 's/^font-size\s*=\s*.*/font-size = 15/' \
            -e 's/^background-opacity\s*=\s*.*/background-opacity = 1/'
        ;;
    *helix/config.toml)
        "$SED_BIN" -E 's/^theme\s*=\s*".*"/theme = "dracula"/'
        ;;
    *zellij/config.kdl)
        "$SED_BIN" -E 's/^theme\s+".+"/theme "dracula-pro"/'
        ;;
    *btop/btop.conf)
        "$SED_BIN" -E 's/^color_theme\s*=\s*".*"/color_theme = "dracula"/'
        ;;
    *bat/config)
        "$SED_BIN" -E 's/^--theme=.*/--theme="Dracula"/'
        ;;
    *git/config|*git/delta-theme.conf)
        "$SED_BIN" -E '/^\[delta\]/,/^\[/ {
            s/^(\s+)light\s*=\s*.*/\1light = false/
            s/^(\s+)syntax-theme\s*=\s*.+/\1syntax-theme = Dracula/
            /^\s+features\s*=.*/d
        }'
        ;;
    *)
        cat
        ;;
esac
