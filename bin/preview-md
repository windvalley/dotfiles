#!/bin/bash
# Preview markdown file using glow in a floating zellij pane
# Usage: preview-md <filename>

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

usage() {
    printf 'Usage: preview-md <filename>\n'
}

if ! command -v glow &>/dev/null; then
    error "glow is required. Please install it with 'brew install glow'."
    exit 1
fi

if ! command -v zellij &>/dev/null; then
    error "zellij is required."
    exit 1
fi

if [ "$#" -ne 1 ]; then
    usage
    exit 1
fi

markdown_file="$1"

if [ ! -f "$markdown_file" ]; then
    error "Markdown file not found: $markdown_file"
    exit 1
fi

zellij run --floating --height 80% --width 60% -x 20% -y 10% --name 'Markdown Preview' -- glow -t "$markdown_file"
