#!/bin/bash
# check-shell-baseline
#
# Enforce the repository Bash baseline:
#   1. strict mode
#   2. unified log helpers

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

info() { echo -e "${BLUE}[INFO]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

is_bash_script() {
    local script="$1"
    [ -f "$script" ] && head -1 "$script" | grep -qx '#!/bin/bash'
}

main() {
    local errors=0
    local script=""
    local -a scripts=()
    local -a missing=()

    info "Checking repository Bash baseline..."

    scripts=(bootstrap.sh install.sh macos.sh)
    while IFS= read -r script; do
        scripts+=("$script")
    done < <(rg --files bin)

    for script in "${scripts[@]}"; do
        if ! is_bash_script "$script"; then
            continue
        fi

        missing=()
        if ! grep -Fq 'set -euo pipefail' "$script"; then
            missing+=('set -euo pipefail')
        fi
        if ! grep -Fq 'info() {' "$script"; then
            missing+=('info()')
        fi
        if ! grep -Fq 'success() {' "$script"; then
            missing+=('success()')
        fi
        if ! grep -Fq 'warn() {' "$script"; then
            missing+=('warn()')
        fi
        if ! grep -Fq 'error() {' "$script"; then
            missing+=('error()')
        fi

        if [ "${#missing[@]}" -eq 0 ]; then
            success "$script"
        else
            error "$script 缺少基线项: ${missing[*]}"
            errors=$((errors + 1))
        fi
    done

    if [ "$errors" -gt 0 ]; then
        error "Bash 基线检查失败，共 $errors 个脚本不符合要求"
        exit 1
    fi

    success "Bash 基线检查通过"
}

main "$@"
