# ============================================================
# Fish 本地私有环境变量与别名配置示例
#
# 任何包含密码、API密钥、或仅存在于当前电脑上的宿主网络别名，
# 都不应该写进公开的 config.fish 中，而应该放在这里。
#
# 使用方法：
# cp config.local.fish.example ~/.fish.local.fish
# 执行 exec fish 即可生效。
# ============================================================

# --- AI 路由顺序 ---
# AI相关工作流使用的默认后端顺序：本地 q 优先，失败后回退到 aichat
# set -gx AI_CHAT_BACKENDS "q,aichat"
#
# 如果你仍希望优先走 aichat，可切换为：
# set -gx AI_CHAT_BACKENDS "aichat,q"

# --- q命令：使用 Ollama 部署的本地模型 ---
# q 命令默认使用的本地 Ollama 模型, 请以 `ollama list` 的 NAME 列为准
# set -gx AI_LOCAL_MODEL "qwen3.5:35b"
#
# 本地 q 命令默认关闭 thinking（速度快）；支持 false / true / low / medium / high
# set -gx AI_LOCAL_THINK "false"

# --- aichat：云端模型 & 本地模型 ---
# provider 前缀提示：OpenAI 用 openai:，Gemini 用 gemini:，Anthropic 用 claude:，
#   Qwen 用 qianwen:，智谱用 zhipuai:，MiniMax 用 minimax:，Moonshot 用 moonshot:，
#   本地 Ollama 用 local-llm:
# set -gx AICHAT_MODEL "gemini:gemini-3-flash-preview"

# --- aichat: 云端 API Key (如果使用本地 Ollama 无需 API Key ---
# set -gx OPENAI_API_KEY "sk-xxxxxxxxx"
# set -gx GEMINI_API_KEY "AIzaSy..."
# set -gx ANTHROPIC_API_KEY "sk-ant-..."
# set -gx ZHIPUAI_API_KEY "xxxxxxxx"
# set -gx MINIMAX_API_KEY "xxxxxxxx"
# set -gx QIANWEN_API_KEY "sk-xxxxxxxx"
# set -gx MOONSHOT_API_KEY "sk-xxxxxxxx"

# --- github token ---
# 强烈建议配置，用于提升 mise/Homebrew 等工具调用 GitHub API 的频率限制
# 获取方式：https://github.com/settings/tokens (申请 Classic Token，无需勾选任何权限即可)
# set -gx GITHUB_TOKEN "ghp_xxxxxxxx"
